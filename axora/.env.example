# Axora Environment Variables
# Copy this file to .env and fill in your values.
# These are OPTIONAL overrides — Axora's config.yaml is the primary config.

# Override config directory
# AXORA_CONFIG_DIR=$HOME/.axora

# Override log file path
# AXORA_LOG_FILE=logs/axora.log

# Quick API key injection (alternative to 'axora config set --secret')
# AXORA_OPENAI_KEY=sk-...
# AXORA_ANTHROPIC_KEY=sk-ant-...
# AXORA_GROQ_KEY=gsk_...
# AXORA_GEMINI_KEY=...

# Local server overrides
# AXORA_HOST=127.0.0.1
# AXORA_PORT=8765

# Remote endpoint URL shortcut
# AXORA_REMOTE_URL=https://api.myserver.com
# AXORA_REMOTE_TOKEN=my-bearer-token
